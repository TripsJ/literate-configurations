    local repo_dir="$HOME/.dotfiles"
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run)
                dry_run=true
                shift
                ;;
            -h|--help)
                echo "Usage: backup [--dry-run]"
                echo "  --dry-run    Show what would be copied without making changes"
                echo "  --help       Show this help message"
                return 0
                ;;
            *)
                echo "Unknown option: $1"
                echo "Use --help for usage information"
                return 1
                ;;
        esac
    done
    
    # Color codes for output
    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local BLUE='\033[0;34m'
    local NC='\033[0m' # No Color
    local BOLD='\033[1m'
    
    echo -e "${BOLD}${BLUE}=== Dotfiles Backup ===${NC}"
    echo
    
    # Run mackup backup first
    echo -e "${BLUE}Running mackup backup...${NC}"
    if [[ "$dry_run" == true ]]; then
        echo -e "${YELLOW}[DRY RUN] Would run: mackup backup${NC}"
    else
        if command -v mackup >/dev/null 2>&1; then
            mackup backup
            if [[ $? -ne 0 ]]; then
                echo -e "${RED}Error: mackup backup failed${NC}"
                return 1
            fi
            echo -e "${GREEN}mackup backup completed${NC}"
        else
            echo -e "${RED}Error: mackup command not found${NC}"
            return 1
        fi
    fi
    echo
    
    # Check if source directory exists
    if [[ ! -d "$source_dir" ]]; then
        echo -e "${RED}Error: Source directory $source_dir does not exist${NC}"
        return 1
    fi
    
    # Check if we're in a git repository
    if [[ ! -d "$repo_dir/.git" ]]; then
        echo -e "${RED}Error: $repo_dir is not a git repository${NC}"
        return 1
    fi
    
    # Create destination directory if it doesn't exist
    if [[ ! -d "$dest_dir" ]]; then
        if [[ "$dry_run" == true ]]; then
            echo -e "${YELLOW}[DRY RUN] Would create directory: $dest_dir${NC}"
        else
            echo -e "${BLUE}Creating destination directory...${NC}"
            mkdir -p "$dest_dir"
            if [[ $? -ne 0 ]]; then
                echo -e "${RED}Error: Failed to create destination directory${NC}"
                return 1
            fi
        fi
    fi
    
    echo -e "${BLUE}Scanning for files to copy...${NC}"
    
    # Find files to copy (excluding .bak files)
    local files_to_copy=()
    while IFS= read -r -d '' file; do
        files_to_copy+=("$file")
    done < <(find "$source_dir" -type f ! -name "*.bak" -print0)
    
    if [[ ${#files_to_copy[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No files found to copy${NC}"
        return 0
    fi
    
    echo -e "${GREEN}Found ${#files_to_copy[@]} files to process${NC}"
    
    if [[ "$dry_run" == true ]]; then
        echo -e "${YELLOW}${BOLD}=== DRY RUN MODE ===${NC}"
        echo "Files that would be copied:"
        for file in "${files_to_copy[@]}"; do
            local rel_path="${file#$source_dir/}"
            echo "  $rel_path"
        done
        return 0
    fi
    
    # Progress bar function
    show_progress() {
        local current=$1
        local total=$2
        local width=50
        local percentage=$((current * 100 / total))
        local completed=$((current * width / total))
        local remaining=$((width - completed))
        
        printf "\r${BLUE}Progress: ["
        printf "%${completed}s" | tr ' ' '='
        printf "%${remaining}s" | tr ' ' '-'
        printf "] %d%% (%d/%d)${NC}" "$percentage" "$current" "$total"
    }
    
    # Copy files with progress bar
    echo -e "${BLUE}Copying files...${NC}"
    local copied_count=0
    local total_files=${#files_to_copy[@]}
    
    for file in "${files_to_copy[@]}"; do
        local rel_path="${file#$source_dir/}"
        local dest_file="$dest_dir/$rel_path"
        local dest_subdir=$(dirname "$dest_file")
        
        # Create subdirectory if needed
        mkdir -p "$dest_subdir"
        
        # Copy file
        cp "$file" "$dest_file"
        if [[ $? -ne 0 ]]; then
            echo -e "\n${RED}Error: Failed to copy $rel_path${NC}"
            return 1
        fi
        
        ((copied_count++))
        show_progress $copied_count $total_files
    done
    
    echo # New line after progress bar
    echo -e "${GREEN}Successfully copied $copied_count files${NC}"
    
    # Change to repo directory
    cd "$repo_dir" || {
        echo -e "${RED}Error: Cannot change to repository directory${NC}"
        return 1
    }
    
    # Check for changes
    echo -e "${BLUE}Checking for git changes...${NC}"
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        echo -e "${GREEN}Changes detected${NC}"
        
        # Show diff
        echo -e "${BLUE}${BOLD}=== Changes to be committed ===${NC}"
        git diff || true
        echo
        
        # Get commit message
        echo -e "${YELLOW}Enter commit message (format: 'appname: description' or general description):${NC}"
        read -r commit_message
        
        if [[ -z "$commit_message" ]]; then
            echo -e "${YELLOW}No commit message provided, aborting${NC}"
            return 1
        fi
        
        # Add changes
        echo -e "${BLUE}Adding changes to git...${NC}"
        git add .
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}Error: Failed to add changes to git${NC}"
            return 1
        fi
        
        # Commit changes
        echo -e "${BLUE}Committing changes...${NC}"
        git commit -m "$commit_message"
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}Error: Failed to commit changes${NC}"
            return 1
        fi
        
        # Push changes
        echo -e "${BLUE}Pushing changes...${NC}"
        git push
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}Error: Failed to push changes${NC}"
            echo -e "${YELLOW}Changes have been committed locally but not pushed${NC}"
            return 1
        fi
        
        echo -e "${GREEN}${BOLD}✓ Successfully backed up all dotfiles!${NC}"
        
    else
        echo -e "${YELLOW}No changes detected in dotfiles repository${NC}"
    fi
    
    return 0
}

# Add completion for the dry-run flag
_backup_completion() {
    local cur=${COMP_WORDS[COMP_CWORD]}
    local opts="--dry-run --help"
    COMPREPLY=($(compgen -W "$opts" -- "$cur"))
}

complete -F _backup_completion backup


